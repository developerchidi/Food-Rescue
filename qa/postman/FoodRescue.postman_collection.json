  "info": {
    "name": "Food Rescue API Integration",
    "_postman_id": "9efb6eb4-c212-4aa6-b865-c8ff3d31fd6d",
    "description": "Integration/API tests for auth, posts, and donations modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  pm.collectionVariables.set('runId', Date.now().toString());",
          "}",
          "if (!pm.collectionVariables.get('donorEmail')) {",
          "  pm.collectionVariables.set('donorEmail', `donor_${pm.collectionVariables.get('runId')}@example.com`);",
          "}",
          "if (!pm.collectionVariables.get('receiverEmail')) {",
          "  pm.collectionVariables.set('receiverEmail', `receiver_${pm.collectionVariables.get('runId')}@example.com`);",
          "}",
          "if (!pm.collectionVariables.get('intruderEmail')) {",
          "  pm.collectionVariables.set('intruderEmail', `intruder_${pm.collectionVariables.get('runId')}@example.com`);",
          "}",
          "pm.collectionVariables.set('futureIso', new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString());"
        ]
      }
    }
  ],
