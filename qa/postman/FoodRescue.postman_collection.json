            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Combo chieu con han\",\n  \"description\": \"Com + ga + rau\",\n  \"type\": \"INDIVIDUAL\",\n  \"originalPrice\": 120000,\n  \"rescuePrice\": 60000,\n  \"quantity\": 2,\n  \"expiryDate\": \"{{futureIso}}\",\n  \"imageUrl\": \"https://example.com/post.jpg\"\n}"
            },
            "url": "{{baseUrl}}/api/posts"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = {}; try { data = pm.response.json(); } catch (e) {}",
                  "pm.collectionVariables.set('postId', data.id);",
