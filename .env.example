# Next.js server → Express (dev). Tránh để client gọi nhầm localhost:3000.
BACKEND_INTERNAL_URL="http://127.0.0.1:3001"

# Database (một biến). Supabase migrate treo → SQL Editor + file Backend/prisma/sql/add_user_profile_columns_supabase.sql
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/food_rescue?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=food_rescue
# Authentication (Auth.js v5 / NextAuth)
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
# JWT do Backend ký sau khi login (middleware bảo vệ API). Nên đặt giống nhau mọi nơi load .env.
JWT_SECRET="your-jwt-secret-here"
# CORS (Backend): origin trình duyệt được phép gọi API (thường trùng URL Next).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# REDIS (Upstash) — Backend đọc các biến này (kèm Frontend/.env nếu dùng load-env).
# Checkout hold + đồng bộ tồn kho: cần URL/TOKEN hợp lệ, hoặc USE_MEMORY_REDIS=1 trên dev.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Dev khi Upstash/DNS lỗi: bỏ qua Redis cloud, dùng bộ nhớ trong process (không dùng production)
USE_MEMORY_REDIS=""
# Hoặc chỉ tắt rate limit Upstash (vẫn có thể dùng Redis thật cho giữ chỗ nếu URL hợp lệ)
DISABLE_UPSTASH_RATELIMIT=""

# EMAIL SERVICE (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ADMIN CONFIG
ADMIN_EMAIL="admin@example.com"
LIST_ADMIN="admin@example.com, partner@example.com"
# Mật khẩu cho user được seed từ ADMIN_EMAIL (không trùng *@example.com). Mặc định: password123
SEED_ADMIN_PASSWORD=""

# Storage (Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
